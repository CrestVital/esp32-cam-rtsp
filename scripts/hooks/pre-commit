#!/bin/sh
# Pre-commit hook: branch guard, printf detector, changelog reminder.
# Install: copy to .git/hooks/pre-commit and make executable.

set -e

# ── Branch guard ──────────────────────────────────────────────────────────
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
    echo "[pre-commit] ERROR: Direct commits to $BRANCH are not allowed."
    echo "             Create a feature branch and open a pull request."
    exit 1
fi

# ── printf() detector (excludes third-party/) ────────────────────────────
PRINTF_FILES=$(git diff --cached --name-only | \
    grep -E '\.(c|h)$' | \
    grep -v '^third-party/' | \
    xargs grep -lP '(?<![a-z])printf\s*\(' 2>/dev/null || true)

if [ -n "$PRINTF_FILES" ]; then
    echo "[pre-commit] ERROR: printf() found in the following files:"
    echo "$PRINTF_FILES"
    echo "             Use ESP_LOG* macros instead of printf()."
    exit 1
fi

# ── CHANGELOG reminder ────────────────────────────────────────────────────
if ! git diff --cached --name-only | grep -q "CHANGELOG.md"; then
    echo "[pre-commit] WARNING: CHANGELOG.md is not staged."
    echo "             Remember to document your change."
fi

exit 0