# Normalize line endings to LF on commit for all text files.
# Developers on Windows get CRLF in their working tree (eol=crlf),
# developers on Unix/macOS get LF (eol=lf).
* text=auto eol=lf

# Explicit text files — always LF
*.c     text eol=lf
*.h     text eol=lf
*.cpp   text eol=lf
*.py    text eol=lf
*.ini   text eol=lf
*.cfg   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.cmake text eol=lf
*.csv   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
Makefile text eol=lf
CMakeLists.txt text eol=lf
*.defaults text eol=lf
sdkconfig* text eol=lf
.gitattributes text eol=lf
.editorconfig  text eol=lf

# Shell scripts — LF mandatory
*.sh    text eol=lf

# Windows batch/PowerShell — keep CRLF
*.bat   text eol=crlf
*.ps1   text eol=crlf

# Binary files — no normalization
*.bin   binary
*.elf   binary
*.a     binary
*.o     binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary
*.gz    binary