# Board selection
CONFIG_BOARD_LILYGO_T_CAMERA_PLUS=y

# Sensor selection
CONFIG_SENSOR_OV2640=y

# Status indicator: display present
CONFIG_STATUS_INDICATOR_HAS_DISPLAY=y

# PSRAM: 8 MB quad-SPI (ESP32, not S3 — no OCT/OPI mode)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_QUAD=y
CONFIG_SPIRAM_SPEED_80M=y

# Flash: 4 MB
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y